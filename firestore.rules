rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Verification codes — only accessible via Cloud Functions (Admin SDK)
    match /verificationCodes/{email} {
      allow read, write: if false;
    }

    // Default: allow authenticated users to read/write their own data
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
